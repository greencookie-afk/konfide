// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TALKER
  LISTENER
  ADMIN
}

enum SessionStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum SessionPaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id                        String                     @id @default(cuid())
  name                      String?
  email                     String                     @unique
  emailVerified             Boolean                    @default(false)
  passwordHash              String?
  googleSubject             String?                    @unique
  avatarUrl                 String?
  browserNotificationsEnabled Boolean                  @default(false)
  browserNotificationPermission String?
  role                      UserRole
  listenerProfile           ListenerProfile?
  listenerSettings          ListenerSettings?
  listenerAvailabilitySlots ListenerAvailabilitySlot[] @relation("ListenerAvailabilitySlots")
  listenerSessions          SessionBooking[]           @relation("ListenerSessions")
  talkerSessions            SessionBooking[]           @relation("TalkerSessions")
  sentSessionMessages       SessionChatMessage[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
}

model AuthRateLimitBucket {
  id          String   @id @default(cuid())
  action      String
  key         String
  windowStart DateTime
  count       Int      @default(1)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([action, key, windowStart])
  @@index([expiresAt])
}

model ListenerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  slug               String   @unique
  headline           String?
  about              String?
  ratePerMinuteCents Int?
  specialties        String[] @default([])
  languages          String[] @default([])
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ListenerSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  timezone             String   @default("Asia/Kolkata")
  defaultSessionMinutes Int     @default(45)
  bufferMinutes        Int      @default(15)
  acceptingNewBookings Boolean  @default(true)
  lastActiveAt         DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([acceptingNewBookings, lastActiveAt])
}

model ListenerAvailabilitySlot {
  id          String   @id @default(cuid())
  listenerId  String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listener User @relation("ListenerAvailabilitySlots", fields: [listenerId], references: [id], onDelete: Cascade)

  @@index([listenerId, dayOfWeek])
}

model SessionBooking {
  id                     String               @id @default(cuid())
  listenerId             String
  talkerId               String
  scheduledAt            DateTime
  durationMinutes        Int
  topic                  String?
  notes                  String?
  ratePerMinuteCents     Int
  totalAmountCents       Int
  status                 SessionStatus        @default(CONFIRMED)
  paymentStatus          SessionPaymentStatus @default(UNPAID)
  paymentOrderId         String?
  paymentTransactionId   String?
  paymentSignature       String?
  paidAt                 DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  listener User @relation("ListenerSessions", fields: [listenerId], references: [id], onDelete: Cascade)
  talker   User @relation("TalkerSessions", fields: [talkerId], references: [id], onDelete: Cascade)
  messages SessionChatMessage[]

  @@index([listenerId, scheduledAt])
  @@index([talkerId, scheduledAt])
  @@index([paymentStatus, scheduledAt])
}

model SessionChatMessage {
  id        String         @id @default(cuid())
  sessionId String
  senderId  String
  body      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  session SessionBooking @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender  User           @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([senderId, createdAt])
}
